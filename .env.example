# Eliano Webmail Environment Variables
# Copie este arquivo para .env e configure suas variáveis

# MySQL Database Configuration (ALTERE O IP DO SEU SERVIDOR)
DATABASE_URL="mysql://eliano_user:sua_senha_aqui@SEU_IP_SERVIDOR:3306/eliano_webmail"

# Exemplo para servidor local:
# DATABASE_URL="mysql://eliano_user:minhasenha123@localhost:3306/eliano_webmail"

# Exemplo para servidor remoto:
# DATABASE_URL="mysql://eliano_user:minhasenha123@192.168.1.100:3306/eliano_webmail"

# Application Configuration
NODE_ENV=development
PORT=5000

# Email Configuration (para envio real de emails - opcional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASS=sua_senha_app
# SMTP_SECURE=false

# Session Configuration (gere uma chave secreta segura)
SESSION_SECRET=sua_chave_secreta_muito_longa_e_aleatoria_aqui

# File Upload Configuration
# MAX_FILE_SIZE=10485760  # 10MB em bytes
# UPLOAD_PATH=./uploads